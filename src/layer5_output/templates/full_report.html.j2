<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ stock_name }} 机构级投研报告</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
         background: #0f172a; color: #e2e8f0; line-height: 1.6; }
  .container { max-width: 1100px; margin: 0 auto; padding: 24px 16px; }
  h2 { color: #f1f5f9; font-size: 1.2rem; margin: 28px 0 12px;
       border-left: 4px solid #3b82f6; padding-left: 12px; }

  /* Module cards */
  .module-card {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px; margin-bottom: 16px; overflow: hidden;
  }
  .mc-header {
    display: flex; align-items: center; gap: 12px;
    background: rgba(255,255,255,0.06); padding: 12px 16px;
  }
  .mc-id { font-size: 0.7rem; font-weight: 700; opacity: 0.5; min-width: 36px; }
  .mc-title { flex: 1; font-weight: 600; font-size: 0.95rem; }
  .mc-score { font-size: 0.85rem; font-weight: 600; }
  .mc-body { padding: 14px 16px; font-size: 0.88rem; }
  .mc-conclusion { margin-bottom: 10px; }
  .mc-tags { margin: 8px 0; }
  .mc-risks { margin: 8px 0; }
  .risk-item { color: #fca5a5; font-size: 0.82rem; margin: 3px 0; }
  .mc-evidence { background: rgba(0,0,0,0.2); border-radius: 8px;
                  padding: 10px; margin: 10px 0; }
  .ev-title { font-size: 0.72rem; opacity: 0.5; margin-bottom: 6px; }
  .ev-item { font-size: 0.8rem; margin: 4px 0; }
  .ev-strong { color: #86efac; }
  .ev-medium { color: #fde68a; }
  .ev-weak   { color: #94a3b8; }
  .ev-type { font-weight: 600; margin-right: 6px; }
  .ev-source { opacity: 0.6; font-style: italic; }
  .mc-suggestions { font-size: 0.82rem; color: #93c5fd; margin-top: 8px; }
  .sug-label { font-weight: 600; }
  .mc-missing { font-size: 0.78rem; color: #94a3b8; margin-top: 8px;
                border-top: 1px solid rgba(255,255,255,0.06); padding-top: 6px; }

  /* Tags */
  .tag { display: inline-block; border-radius: 6px; padding: 2px 8px;
         font-size: 0.72rem; font-weight: 600; margin: 2px;
         background: rgba(255,255,255,0.1); }
  .tag.blue   { background: #1e3a5f44; color: #93c5fd; }
  .tag.green  { background: #15803d33; color: #86efac; }
  .tag.yellow { background: #92400e33; color: #fde68a; }
  .tag.red    { background: #7f1d1d33; color: #fca5a5; }

  /* Scenario table */
  .scenario-table { width: 100%; border-collapse: collapse; margin: 12px 0; }
  .scenario-table th, .scenario-table td {
    border: 1px solid rgba(255,255,255,0.1); padding: 10px 12px;
    font-size: 0.83rem; text-align: left; vertical-align: top;
  }
  .scenario-table th { background: rgba(255,255,255,0.06); font-weight: 600; }
  .sc-bull  { color: #22c55e; }
  .sc-neutral { color: #fbbf24; }
  .sc-bear { color: #f97316; }
  .sc-tail { color: #ef4444; }

  /* Trade action */
  .trade-action-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 12px; margin: 12px 0;
  }
  .ta-box {
    background: rgba(255,255,255,0.04); border-radius: 10px;
    border: 1px solid rgba(255,255,255,0.08); padding: 14px;
  }
  .ta-box h4 { font-size: 0.82rem; opacity: 0.6; margin-bottom: 8px;
               text-transform: uppercase; letter-spacing: 0.05em; }
  .ta-box p  { font-size: 0.88rem; }
  .ta-forbid { color: #ef4444; }

  /* Investor profile table */
  .profile-table { width: 100%; border-collapse: collapse; }
  .profile-table th, .profile-table td {
    border: 1px solid rgba(255,255,255,0.1); padding: 8px 12px;
    font-size: 0.83rem;
  }
  .profile-table th { background: rgba(255,255,255,0.06); font-weight: 600; }
  .suitable-yes { color: #86efac; }
  .suitable-maybe { color: #fde68a; }
  .suitable-no  { color: #fca5a5; }

  /* Risk disclaimer */
  .risk-disclaimer {
    background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.2);
    border-radius: 10px; padding: 16px; margin-top: 32px;
    font-size: 0.8rem; color: #fca5a5; line-height: 1.7;
  }

  /* Checklist */
  .checklist { list-style: none; padding: 0; }
  .checklist li { padding: 5px 0; font-size: 0.88rem; }
  .checklist li::before { content: "□ "; color: #3b82f6; }
</style>
</head>
<body>
<div class="container">

  <!-- === FIRST SCREEN: Three Score Cards (injected from scorecard template) === -->
  {{ scorecard_html | safe }}

  <!-- === MODULE ANALYSIS SECTIONS === -->
  <h2>▌ 基本面分析（批次A）</h2>
  {{ module_m01 | safe }}
  {{ module_m02 | safe }}
  {{ module_m03 | safe }}
  {{ module_m04 | safe }}
  {{ module_m05 | safe }}

  <h2>▌ 市场面分析（批次B）</h2>
  {{ module_m06 | safe }}
  {{ module_m07 | safe }}
  {{ module_m08 | safe }}
  {{ module_m09 | safe }}
  {{ module_m10 | safe }}
  {{ module_m11 | safe }}

  <h2>▌ 深度分析（批次C）</h2>
  {{ module_m12 | safe }}
  {{ module_m13 | safe }}
  {{ module_m19 | safe }}
  {{ module_m20 | safe }}
  {{ module_m21 | safe }}
  {{ module_m22 | safe }}

  <h2>▌ 综合决策（批次D）</h2>
  {{ module_m14 | safe }}
  {{ module_m15 | safe }}
  {{ module_m23 | safe }}
  {{ module_m24 | safe }}
  {{ module_m25 | safe }}

  <!-- === FOUR SCENARIOS === -->
  <h2>▌ 四情景推演</h2>
  <table class="scenario-table">
    <thead>
      <tr>
        <th>情景</th><th>触发条件</th>
        <th>目标价区间</th><th>概率</th>
        <th>时间维度</th><th>应对策略</th>
      </tr>
    </thead>
    <tbody>
    {% for sc in scenarios %}
    <tr>
      <td><strong class="
        {%- if sc.name == '乐观情景' %}sc-bull
        {%- elif sc.name == '中性情景' %}sc-neutral
        {%- elif sc.name == '悲观情景' %}sc-bear
        {%- else %}sc-tail{% endif %}">{{ sc.name }}</strong></td>
      <td>{{ sc.trigger_conditions | join('<br>') | safe }}</td>
      <td>{{ sc.price_target_range }}</td>
      <td>{{ sc.probability }}</td>
      <td>{{ sc.time_horizon }}</td>
      <td>{{ sc.strategy }}</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>

  <!-- === TRADE ACTION === -->
  <h2>▌ 标准化交易动作计划</h2>
  <p style="margin-bottom:12px; font-size:0.95rem; font-weight:600; color:#f1f5f9;">
    一句话总判断：{{ trade_action.one_line_verdict }}
  </p>
  <div class="trade-action-grid">
    <div class="ta-box">
      <h4>建仓方案</h4>
      <p>最优建仓区：{{ trade_action.entry_zone }}<br>
         试仓比例：{{ trade_action.entry_ratio }}<br>
         加仓条件：{{ trade_action.add_position_condition }}</p>
    </div>
    <div class="ta-box">
      <h4>持仓方案</h4>
      <p>底仓持有：{{ '是' if trade_action.hold_bottom else '否' }}<br>
         做T：{{ '是' if trade_action.do_t_trade else '否' }}<br>
         锁盈减仓：{{ '是' if trade_action.reduce_to_lock_profit else '否' }}</p>
    </div>
    <div class="ta-box">
      <h4>止损方案</h4>
      <p>硬止损位：<strong style="color:#ef4444">{{ trade_action.hard_stop_loss }}</strong><br>
         逻辑止损：{{ trade_action.logic_stop_condition }}<br>
         事件止损：{{ trade_action.event_stop_condition }}</p>
    </div>
    <div class="ta-box">
      <h4>止盈方案</h4>
      <p>第一目标：<strong style="color:#22c55e">{{ trade_action.target_1 }}</strong><br>
         第二目标：{{ trade_action.target_2 }}<br>
         事件兑现：{{ trade_action.event_tp_strategy }}</p>
    </div>
    <div class="ta-box">
      <h4>禁做清单</h4>
      {% for c in trade_action.forbid_chase_conditions %}
      <p class="ta-forbid">🚫 {{ c }}</p>
      {% endfor %}
      {% for c in trade_action.forbid_bottom_fish_conditions %}
      <p class="ta-forbid">🚫 {{ c }}</p>
      {% endfor %}
      {% for c in trade_action.forbid_leverage_conditions %}
      <p class="ta-forbid">🚫 {{ c }}</p>
      {% endfor %}
    </div>
  </div>

  <!-- === INVESTOR PROFILES === -->
  <h2>▌ 适用投资者画像</h2>
  <table class="profile-table">
    <thead>
      <tr>
        <th>投资者类型</th>
        <th>是否适合</th>
        <th>仓位上限</th>
        <th>推荐周期</th>
        <th>最大容忍回撤</th>
      </tr>
    </thead>
    <tbody>
    {% for p in investor_profiles %}
    <tr>
      <td>{{ p.investor_type }}</td>
      <td class="{%- if p.suitable == '适合' %}suitable-yes
                 {%- elif p.suitable == '一般' %}suitable-maybe
                 {%- else %}suitable-no{% endif %}">{{ p.suitable }}</td>
      <td>{{ p.position_limit }}</td>
      <td>{{ p.recommended_period }}</td>
      <td>{{ p.max_drawdown_tolerance }}</td>
    </tr>
    {% endfor %}
    </tbody>
  </table>

  <!-- === INVALIDATION CHECKLIST === -->
  <h2>▌ 逻辑失效条件 & 动态跟踪清单</h2>
  <div style="display:grid; grid-template-columns:1fr 1fr; gap:16px; margin:12px 0;">
    <div>
      <h3 style="font-size:0.9rem; color:#fca5a5; margin-bottom:8px;">逻辑失效条件（触发即止损）</h3>
      <ul class="checklist">
        {% for item in invalidation_checklist %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
    <div>
      <h3 style="font-size:0.9rem; color:#93c5fd; margin-bottom:8px;">动态跟踪清单（每周复查）</h3>
      <ul class="checklist">
        {% for item in tracking_checklist %}
        <li>{{ item }}</li>
        {% endfor %}
      </ul>
    </div>
  </div>

  <!-- === RISK DISCLAIMER === -->
  <div class="risk-disclaimer">
    <strong>【风险提示】</strong>
    本分析基于公开市场数据、量化模型与机构投研框架推演生成，综合投资价值评分、现价买入性价比评分、
    交易执行确定性评分均为模型测算结果，仅供研究参考，不构成任何投资建议。A股市场受政策、流动性、
    业绩、风险偏好、突发事件等多因素影响，短期波动可能显著偏离基本面。现价买入性价比评分与交易执行
    确定性评分仅反映当前时点的阶段性交易条件，具有较强时效性；一旦市场环境、公司业绩、股东行为、
    流动性结构发生变化，评分可能快速失效。请结合自身风险承受能力、投资周期、仓位管理与止损纪律独立
    决策，股市有风险，投资需谨慎。
  </div>

</div>
</body>
</html>
